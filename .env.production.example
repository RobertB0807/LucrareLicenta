POSTGRES_DB=cyber_training
POSTGRES_USER=cyber_training
POSTGRES_PASSWORD=replace-with-a-strong-database-password

JWT_SECRET_KEY=replace-with-a-unique-random-secret-of-at-least-32-characters
APP_CORS_ORIGINS=https://app.example.com

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

API_WORKERS=1
API_PORT=8000

# Optional error tracking.
LOG_LEVEL=INFO
LOG_JSON=true
METRICS_ENABLED=true

# Optional Firebase Auth backend verification.
# Prefer FIREBASE_SERVICE_ACCOUNT_JSON in production deployment secrets.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# Optional local/production LLM provider. Keep disabled unless Ollama or another provider is reachable.
LLM_ENABLED=false
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
LLM_TIMEOUT_SECONDS=60

# Optional live email drills. Leave disabled for dry-run behavior.
LIVE_DRILL_PUBLIC_BASE_URL=https://api.example.com
LIVE_DRILL_EMAIL_ENABLED=false
LIVE_DRILL_SMTP_HOST=
LIVE_DRILL_SMTP_PORT=587
LIVE_DRILL_SMTP_USERNAME=
LIVE_DRILL_SMTP_PASSWORD=
LIVE_DRILL_SMTP_TLS=true
LIVE_DRILL_EMAIL_FROM=
