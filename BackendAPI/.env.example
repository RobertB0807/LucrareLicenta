DATABASE_URL=sqlite:///BackendAPI/training_data.db
JWT_SECRET_KEY=dev-insecure-secret-change-me
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# Optional local scenario generation through Ollama.
LLM_ENABLED=false
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
LLM_TIMEOUT_SECONDS=60

# Optional: enables Firebase ID token verification in FastAPI.
# Option A: paste the service account JSON as one line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: path to a Firebase service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=/Users/robertbalasoiu/Robert/Licenta2026/LucrareLicenta/licentaupt2026-firebase-adminsdk-fbsvc-cdf3ad62a5.json

# Optional when using Application Default Credentials.
FIREBASE_PROJECT_ID=licentaupt2026
