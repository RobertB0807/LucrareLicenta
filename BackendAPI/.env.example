APP_ENV=development
DATABASE_URL=sqlite:///BackendAPI/training_data.db
JWT_SECRET_KEY=dev-insecure-secret-change-me
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# Comma-separated exact web origins. Required in production; wildcard origins are rejected.
APP_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Enable only when requests arrive through a trusted reverse proxy that sets X-Forwarded-For.
TRUST_PROXY_HEADERS=false

# Defaults to true outside production and false in production.
API_DOCS_ENABLED=true

# Local development automatically applies Alembic migrations. Production uses a separate migration job.
AUTO_MIGRATE=true

# Optional in development/test. Required in production for distributed rate limiting.
REDIS_URL=
RATE_LIMIT_FAIL_OPEN=true

# Observability. JSON logs default to true in production.
LOG_LEVEL=DEBUG
LOG_JSON=false
METRICS_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Optional local scenario generation through Ollama.
LLM_ENABLED=false
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
LLM_TIMEOUT_SECONDS=60

# Optional: enables Firebase ID token verification in FastAPI.
# Option A: paste the service account JSON as one line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: absolute path to a Firebase service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/firebase-service-account.json

# Optional when using Application Default Credentials.
FIREBASE_PROJECT_ID=your-firebase-project-id
